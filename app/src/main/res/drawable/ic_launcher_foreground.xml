<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Screen backdrop or inner display with soft glow -->
    <path
        android:pathData="M 32,38 C 32,34.7 34.7,32 38,32 L 70,32 C 73.3,32 76,34.7 76,38 L 76,64 C 76,67.3 73.3,70 70,70 L 38,70 C 34.7,70 32,67.3 32,64 Z"
        android:fillAlpha="0.12">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="32"
                android:startY="32"
                android:endX="76"
                android:endY="70"
                android:type="linear">
                <item android:offset="0.0" android:color="#D0BCFF" />
                <item android:offset="1.0" android:color="#381E72" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Outer TV/Casting Monitor Frame with a beautiful glowing gradient -->
    <path
        android:pathData="M 32,38 C 32,34.7 34.7,32 38,32 L 70,32 C 73.3,32 76,34.7 76,38 L 76,64 C 76,67.3 73.3,70 70,70 L 38,70 C 34.7,70 32,67.3 32,64 Z"
        android:strokeWidth="3.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="32"
                android:startY="32"
                android:endX="76"
                android:endY="70"
                android:type="linear">
                <item android:offset="0.0" android:color="#E0C3FC" />
                <item android:offset="0.5" android:color="#A8C2FB" />
                <item android:offset="1.0" android:color="#86A8E7" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- TV Stand -->
    <path
        android:pathData="M 45.5,70 L 42,77 C 42,77.5 42.4,78 43,78 L 65,78 C 65.6,78 66,77.5 66,77 L 62.5,70"
        android:strokeWidth="2.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="42"
                android:startY="70"
                android:endX="66"
                android:endY="78"
                android:type="linear">
                <item android:offset="0.0" android:color="#A8C2FB" />
                <item android:offset="1.0" android:color="#E0C3FC" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Centered Play Icon inside the monitor -->
    <path
        android:pathData="M 51,45 L 61.5,51 L 51,57 Z"
        android:strokeWidth="1"
        android:strokeLineJoin="round">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="51"
                android:startY="45"
                android:endX="61.5"
                android:endY="57"
                android:type="linear">
                <item android:offset="0.0" android:color="#E0C3FC" />
                <item android:offset="1.0" android:color="#86A8E7" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing Chromecast-style casting waves (bottom-left) -->
    <!-- Wave Hub -->
    <path
        android:pathData="M 36,66 m -1.8,0 a 1.8,1.8 0 1,1 3.6,0 a 1.8,1.8 0 1,1 -3.6,0"
        android:fillColor="#FFD8E4" />
    
    <!-- Wave 1 -->
    <path
        android:pathData="M 36,61 A 5,5 0 0,1 41,66"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:strokeColor="#8EC5FC" />
    <!-- Wave 2 -->
    <path
        android:pathData="M 36,56 A 10,10 0 0,1 46,66"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:strokeColor="#D0BCFF" />
    <!-- Wave 3 -->
    <path
        android:pathData="M 36,51 A 15,15 0 0,1 51,66"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:strokeColor="#E0C3FC" />

</vector>
